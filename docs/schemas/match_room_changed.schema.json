{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MatchRoomChanged",
  "description": "Payload schema for the `match_room.changed` WebSocket message.",
  "type": "object",
  "required": [
    "room_id",
    "participants"
  ],
  "properties": {
    "room_id": {
      "type": "string"
    },
    "participants": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "common.schema.json#/$defs/clientIdentity"
          },
          {
            "$ref": "common.schema.json#/$defs/participantIdentifierObject"
          }
        ]
      }
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "room_id": "lm-123",
      "participants": [
        {
          "id": 1,
          "name": "Alice",
          "email": "alice@example.com",
          "avatar": null,
          "guest_id": null
        },
        {
          "id": null,
          "name": "Guest Bob",
          "email": "",
          "avatar": null,
          "guest_id": "7aab8cb6-5cd5-4da7-86b6-a639c1b9857b"
        }
      ]
    },
    {
      "room_id": "lm-123",
      "participants": [
        {
          "id": "1"
        },
        {
          "id": "guest-bob"
        }
      ]
    }
  ]
}
