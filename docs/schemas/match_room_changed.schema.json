{
    "$schema": "http://json-schema.org/draft/2020-12/schema#",
    "title": "MatchRoomChanged",
    "description": "Schema for the payload of the `match_room.changed` WebSocket message.",
    "type": "object",
    "required": [
        "room_id",
        "participants"
    ],
    "properties": {
        "room_id": {
            "type": "string"
        },
        "participants": {
            "type": "array",
            "description": "Array of participants. Each item is either a participant identifier (string) or a full participant object.",
            "items": {
                "oneOf": [
                    {
                        "type": "string",
                        "description": "Participant identifier (e.g. '1' or 'guest-bob')."
                    },
                    {
                        "type": "object",
                        "description": "Full participant object serialized from ClientIdentity.",
                        "required": [
                            "id"
                        ],
                        "properties": {
                            "id": {
                                "type": "string",
                                "description": "Internal participant id or guest id string."
                            },
                            "name": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "nullable": true
                            },
                            "email": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "nullable": true
                            },
                            "avatar": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "nullable": true
                            },
                            "guest_id": {
                                "type": [
                                    "string",
                                    "null"
                                ],
                                "nullable": true
                            }
                        },
                        "additionalProperties": false
                    }
                ]
            }
        },
        "match_params": {
            "type": "object",
            "description": "Optional match parameters (copied from LinkMatch payload)."
        }
    },
    "additionalProperties": true,
    "examples": [
        {
            "room_id": "abc-123",
            "participants": [
                "1",
                "guest-bob"
            ]
        },
        {
            "room_id": "abc-123",
            "participants": [
                {
                    "id": "1",
                    "name": "Alice",
                    "email": "alice@example.com",
                    "avatar": null,
                    "guest_id": null
                },
                {
                    "id": "guest-bob",
                    "name": null,
                    "email": null,
                    "avatar": null,
                    "guest_id": "bob"
                }
            ],
            "match_params": {
                "difficulty": "easy"
            }
        }
    ]
}