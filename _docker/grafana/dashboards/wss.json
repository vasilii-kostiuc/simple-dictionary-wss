            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(wss_connections_opened_total{node=~\"$node\"}[1m])",
          "legendFormat": "open \u2014 {{node}}",
          "refId": "A"
        },
        {
          "expr": "rate(wss_connections_closed_total{node=~\"$node\"}[1m])",
          "legendFormat": "close \u2014 {{node}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Messages Rate by Type",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
