        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(wss_messages_total{node=~\"$node\"}[1m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
