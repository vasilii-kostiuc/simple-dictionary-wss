        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(wss_messages_invalid_json_total{node=~\"$node\"}[1m]))",
          "legendFormat": "invalid JSON",
          "refId": "A"
        },
        {
          "expr": "sum(rate(wss_errors_total{node=~\"$node\"}[1m]))",
          "legendFormat": "errors",
          "refId": "B"
        }
      ]
    },
    {
